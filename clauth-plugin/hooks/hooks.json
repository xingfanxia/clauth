{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_clauth_clauth__delegate$",
        "hooks": [
          {
            "type": "command",
            "command": "clauth mcp-await-job",
            "asyncRewake": true,
            "timeout": 4260,
            "rewakeMessage": "A backgrounded clauth delegate finished; its result envelope follows."
          }
        ]
      }
    ]
  }
}
